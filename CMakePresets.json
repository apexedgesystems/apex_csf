  "testPresets": [
    {
      "name": "_test-base",
      "hidden": true,
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "ignore", "timeout": 300 }
    },
    {
      "name": "hosted-x86_64-debug",
      "inherits": "_test-base",
      "configurePreset": "hosted-x86_64-debug",
      "environment": {
        "LD_LIBRARY_PATH": "${sourceDir}/build/hosted-x86_64-debug/lib:$penv{LD_LIBRARY_PATH}"
      }
    },
    {
      "name": "hosted-x86_64-release",
