{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 24, "patch": 0 },

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": { "CMAKE_EXPORT_COMPILE_COMMANDS": "ON" }
    },

    {
      "name": "native-linux-debug",
      "displayName": "Native (Ubuntu) - Debug",
      "inherits": "base",
      "binaryDir": "build/native-linux-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang-21",
        "CMAKE_CXX_COMPILER": "clang++-21"
      }
    },
    {
      "name": "native-linux-profile",
      "displayName": "Native (Ubuntu) - Profile (gperftools/perf-friendly)",
      "inherits": "base",
      "binaryDir": "build/native-linux-profile",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang-21",
        "CMAKE_CXX_COMPILER": "clang++-21",
        "CMAKE_CXX_FLAGS": "-fno-omit-frame-pointer -gdwarf-4",
        "APEX_USE_SPLIT_DWARF": "OFF"
      }
    },
    {
      "name": "native-linux-release",
      "displayName": "Native (Ubuntu) - Release",
      "inherits": "base",
      "binaryDir": "build/native-linux-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "clang-21",
        "CMAKE_CXX_COMPILER": "clang++-21"
      }
    },

    {
      "name": "native-linux-cuda-debug",
      "displayName": "Native (Ubuntu) - Debug + CUDA (required)",
      "inherits": "native-linux-debug",
      "binaryDir": "build/native-linux-cuda-debug",
      "cacheVariables": { "APEX_REQUIRE_CUDA": "ON" }
    },
    {
      "name": "native-linux-cuda-release",
      "displayName": "Native (Ubuntu) - Release + CUDA (required)",
      "inherits": "native-linux-release",
      "binaryDir": "build/native-linux-cuda-release",
      "cacheVariables": { "APEX_REQUIRE_CUDA": "ON" }
    },

    {
      "name": "native-linux-asan",
      "displayName": "Native (Ubuntu) - Debug + AddressSanitizer",
      "inherits": "native-linux-debug",
      "binaryDir": "build/native-linux-asan",
      "cacheVariables": { "SANITIZER": "asan" }
    },
    {
      "name": "native-linux-tsan",
      "displayName": "Native (Ubuntu) - Debug + ThreadSanitizer",
      "inherits": "native-linux-debug",
      "binaryDir": "build/native-linux-tsan",
      "cacheVariables": { "SANITIZER": "tsan" }
    },
    {
      "name": "native-linux-ubsan",
      "displayName": "Native (Ubuntu) - Debug + UBSanitizer",
      "inherits": "native-linux-debug",
      "binaryDir": "build/native-linux-ubsan",
      "cacheVariables": { "SANITIZER": "ubsan" }
    },
    {
      "name": "native-linux-coverage",
      "displayName": "Native (Ubuntu) - Debug + Coverage (LLVM source-based)",
      "inherits": "native-linux-debug",
      "binaryDir": "build/native-linux-coverage",
      "cacheVariables": {
        "ENABLE_COVERAGE": "ON",
        "APEX_COVERAGE_LLVM_VERSION": "21"
      }
    },
    {
      "name": "native-linux-static",
      "displayName": "Native (Ubuntu) - Debug for scan-build static analysis",
      "inherits": "native-linux-debug",
      "binaryDir": "build/native-linux-static"
    },

    {
      "name": "jetson-aarch64-debug",
      "displayName": "Jetson AGX Thor (aarch64) - Debug",
      "inherits": "base",
      "binaryDir": "build/jetson-aarch64-debug",
      "toolchainFile": "cmake/toolchains/jetson-aarch64.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "OFF",
        "CMAKE_PREFIX_PATH": "/opt/sysroots/jetson-thor/usr",
        "APEX_REQUIRE_CUDA": "ON"
      }
    },
    {
      "name": "jetson-aarch64-release",
      "displayName": "Jetson AGX Thor (aarch64) - Release",
      "inherits": "base",
      "binaryDir": "build/jetson-aarch64-release",
      "toolchainFile": "cmake/toolchains/jetson-aarch64.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "OFF",
        "CMAKE_PREFIX_PATH": "/opt/sysroots/jetson-thor/usr",
        "APEX_REQUIRE_CUDA": "ON"
      }
    },

    {
      "name": "rpi-aarch64-debug",
      "displayName": "Raspberry Pi (aarch64) - Debug",
      "inherits": "base",
      "binaryDir": "build/rpi-aarch64-debug",
      "toolchainFile": "cmake/toolchains/rpi-aarch64.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "OFF"
      }
    },
    {
      "name": "rpi-aarch64-release",
      "displayName": "Raspberry Pi (aarch64) - Release",
      "inherits": "base",
      "binaryDir": "build/rpi-aarch64-release",
      "toolchainFile": "cmake/toolchains/rpi-aarch64.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "OFF"
      }
    },

    {
      "name": "riscv64-linux-debug",
      "displayName": "RISC-V 64 (Linux) - Debug",
      "inherits": "base",
      "binaryDir": "build/riscv64-linux-debug",
      "toolchainFile": "cmake/toolchains/riscv64-linux-gnu.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "OFF"
      }
    },
    {
      "name": "riscv64-linux-release",
      "displayName": "RISC-V 64 (Linux) - Release",
      "inherits": "base",
      "binaryDir": "build/riscv64-linux-release",
      "toolchainFile": "cmake/toolchains/riscv64-linux-gnu.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "OFF"
      }
    },

    {
      "name": "stm32-baremetal",
      "displayName": "STM32 (L476) - Bare-metal",
      "inherits": "base",
      "binaryDir": "build/stm32",
      "toolchainFile": "cmake/toolchains/stm32-gcc.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "APEX_HAL_PLATFORM": "stm32"
      }
    },
    {
      "name": "stm32-baremetal-debug",
      "displayName": "STM32 (L476) - Bare-metal Debug (-Og -g3)",
      "inherits": "stm32-baremetal",
      "binaryDir": "build/stm32-debug",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },

    {
      "name": "zephyr-arm",
      "displayName": "Zephyr RTOS (ARM)",
      "inherits": "base",
      "binaryDir": "build/zephyr-arm",
      "toolchainFile": "cmake/toolchains/zephyr.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "ZEPHYR_BOARD": "nucleo_l476rg"
      }
    },

    {
      "name": "arduino-baremetal",
      "displayName": "Arduino Uno (ATmega328P) - Bare-metal",
      "inherits": "base",
      "binaryDir": "build/arduino",
      "toolchainFile": "cmake/toolchains/avr-gcc.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "APEX_HAL_PLATFORM": "avr"
      }
    },
    {
      "name": "arduino-baremetal-debug",
      "displayName": "Arduino Uno - Bare-metal Debug (-Og -g3)",
      "inherits": "arduino-baremetal",
      "binaryDir": "build/arduino-debug",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },

    {
      "name": "pico-baremetal",
      "displayName": "Pico (RP2040) - Bare-metal",
      "inherits": "base",
      "binaryDir": "build/pico",
      "toolchainFile": "cmake/toolchains/pico-gcc.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "APEX_HAL_PLATFORM": "pico"
      }
    },
    {
      "name": "pico-baremetal-debug",
      "displayName": "Pico (RP2040) - Bare-metal Debug (-Og -g3)",
      "inherits": "pico-baremetal",
      "binaryDir": "build/pico-debug",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },

    {
      "name": "esp32-baremetal",
      "displayName": "ESP32-S3 (Xtensa LX7) - Bare-metal (ESP-IDF)",
      "inherits": "base",
      "binaryDir": "build/esp32",
      "toolchainFile": "cmake/toolchains/esp32-gcc.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "APEX_HAL_PLATFORM": "esp32"
      }
    },
    {
      "name": "esp32-baremetal-debug",
      "displayName": "ESP32-S3 - Bare-metal Debug (-Og -g3)",
      "inherits": "esp32-baremetal",
      "binaryDir": "build/esp32-debug",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },

    {
      "name": "c2000-baremetal",
      "displayName": "TI C2000 F28004x (C28x DSP) - Bare-metal",
      "inherits": "base",
      "binaryDir": "build/c2000",
      "toolchainFile": "cmake/toolchains/c2000-cgt.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "APEX_HAL_PLATFORM": "c2000"
      }
    },
    {
      "name": "c2000-baremetal-debug",
      "displayName": "TI C2000 F28004x - Bare-metal Debug (--opt_level=0)",
      "inherits": "c2000-baremetal",
      "binaryDir": "build/c2000-debug",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    }
  ],

  "buildPresets": [
    { "name": "native-linux-debug",    "configurePreset": "native-linux-debug" },
    { "name": "native-linux-profile",  "configurePreset": "native-linux-profile" },
    { "name": "native-linux-release",  "configurePreset": "native-linux-release" },
    { "name": "native-linux-asan",     "configurePreset": "native-linux-asan" },
    { "name": "native-linux-tsan",     "configurePreset": "native-linux-tsan" },
    { "name": "native-linux-ubsan",    "configurePreset": "native-linux-ubsan" },
    { "name": "native-linux-coverage", "configurePreset": "native-linux-coverage" },
    { "name": "native-linux-static",   "configurePreset": "native-linux-static" },
    { "name": "jetson-aarch64-debug",  "configurePreset": "jetson-aarch64-debug" },
    { "name": "jetson-aarch64-release", "configurePreset": "jetson-aarch64-release" },
    { "name": "rpi-aarch64-debug",     "configurePreset": "rpi-aarch64-debug" },
    { "name": "rpi-aarch64-release",   "configurePreset": "rpi-aarch64-release" },
    { "name": "riscv64-linux-debug",   "configurePreset": "riscv64-linux-debug" },
    { "name": "riscv64-linux-release", "configurePreset": "riscv64-linux-release" },
    { "name": "stm32-baremetal",       "configurePreset": "stm32-baremetal" },
    { "name": "stm32-baremetal-debug", "configurePreset": "stm32-baremetal-debug" },
    { "name": "zephyr-arm",            "configurePreset": "zephyr-arm" },
    { "name": "arduino-baremetal",     "configurePreset": "arduino-baremetal" },
    { "name": "arduino-baremetal-debug","configurePreset": "arduino-baremetal-debug" },
    { "name": "pico-baremetal",        "configurePreset": "pico-baremetal" },
    { "name": "pico-baremetal-debug",  "configurePreset": "pico-baremetal-debug" },
    { "name": "esp32-baremetal",       "configurePreset": "esp32-baremetal" },
    { "name": "esp32-baremetal-debug", "configurePreset": "esp32-baremetal-debug" },
    { "name": "c2000-baremetal",       "configurePreset": "c2000-baremetal" },
    { "name": "c2000-baremetal-debug", "configurePreset": "c2000-baremetal-debug" }
  ],

  "testPresets": [
    { "name": "native-linux-debug",    "configurePreset": "native-linux-debug" },
    { "name": "native-linux-release",  "configurePreset": "native-linux-release" },
    { "name": "native-linux-cuda-debug",   "configurePreset": "native-linux-cuda-debug" },
    { "name": "native-linux-cuda-release", "configurePreset": "native-linux-cuda-release" },
    { "name": "native-linux-asan",     "configurePreset": "native-linux-asan" },
    { "name": "native-linux-tsan",     "configurePreset": "native-linux-tsan" },
    { "name": "native-linux-ubsan",    "configurePreset": "native-linux-ubsan" },
    { "name": "native-linux-coverage", "configurePreset": "native-linux-coverage" },
    { "name": "jetson-aarch64-debug",  "configurePreset": "jetson-aarch64-debug" },
    { "name": "jetson-aarch64-release", "configurePreset": "jetson-aarch64-release" }
  ],

  "workflowPresets": [
    {
      "name": "native-debug",
      "displayName": "Native debug: configure + build + test",
      "steps": [
        { "type": "configure", "name": "native-linux-debug" },
        { "type": "build",     "name": "native-linux-debug" },
        { "type": "test",      "name": "native-linux-debug" }
      ]
    },
    {
      "name": "native-release",
      "displayName": "Native release: configure + build",
      "steps": [
        { "type": "configure", "name": "native-linux-release" },
        { "type": "build",     "name": "native-linux-release" }
      ]
    },
    {
      "name": "native-asan",
      "displayName": "Native AddressSanitizer: configure + build + test",
      "steps": [
        { "type": "configure", "name": "native-linux-asan" },
        { "type": "build",     "name": "native-linux-asan" },
        { "type": "test",      "name": "native-linux-asan" }
      ]
    },
    {
      "name": "native-coverage",
      "displayName": "Native coverage: configure + build + test (Coverage label)",
      "steps": [
        { "type": "configure", "name": "native-linux-coverage" },
        { "type": "build",     "name": "native-linux-coverage" },
        { "type": "test",      "name": "native-linux-coverage" }
      ]
    },
    {
      "name": "jetson-release",
      "displayName": "Jetson release: configure + build",
      "steps": [
        { "type": "configure", "name": "jetson-aarch64-release" },
        { "type": "build",     "name": "jetson-aarch64-release" }
      ]
    }
  ]
}