PROJECT_NAME           = @LIB_NAME@
OUTPUT_DIRECTORY       = @DOCS_DIR@

INPUT                  = @SRC_DIR@ @INC_DIR@ @TST_DIR@ @DOCS_SRC_DIR@ @TOOLS_DIR@ @TEMPLATES_DIR@ @EXTRA_DIRS@ @README_FILE@
USE_MDFILE_AS_MAINPAGE = @README_FILE@

RECURSIVE              = YES

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_XML           = YES
GENERATE_TREEVIEW      = YES
SEARCHENGINE           = YES
MARKDOWN_SUPPORT       = YES
MARKDOWN_ID_STYLE      = GITHUB

# doxygen-awesome-css theme (https://jothepro.github.io/doxygen-awesome-css/)
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_COLORSTYLE        = LIGHT
HTML_EXTRA_STYLESHEET  = @DOXYGEN_AWESOME_CSS_DIR@/doxygen-awesome.css \
                         @DOXYGEN_AWESOME_CSS_DIR@/doxygen-awesome-sidebar-only.css

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
REFERENCED_BY_RELATION = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
INLINE_SOURCES         = YES

HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = png
DOT_GRAPH_MAX_NODES    = 50

STRIP_FROM_PATH        = @CMAKE_SOURCE_DIR@

QUIET                  = YES
WARN_IF_DOC_ERROR      = YES

FILE_PATTERNS          = *.cpp *.hpp *.tpp *.cu *.cuh *.md
GENERATE_TAGFILE       = @DOCS_DIR@/@LIB_NAME@.tag