# Project guide (not public until major release)
CLAUDE.md

# Build artifacts
/build/
/output/
/release/
compile_commands.json

# Coverage / profiling output
*.profraw
*.profdata
heaptrack.*.gz
heaptrack.*.zst
# Editor backups
*.bak

# Temporary files
/tmp/
*.log
/*.csv

# Design docs and future proposals (internal only). Anchored to the repo-root
# docs/ folder -- application docs (demos/*/docs/, apps/*/docs/) are
# user-facing deliverables and are committed.
/docs/
**/docs/design/

# Binary data files (generated gravity coefficients, not committed)
**/*.bin

# IDE and editor
/.vscode/
/.idea/

# Python
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
*.egg-info/
.venv

# Rust
target/
Cargo.lock.bak

# Dev scripts (not committed)
tools/py/dev/
tools/rust/dev/

# Archived test results (kept locally, not committed)
**/.archive/

# User production applications (proprietary, never committed upstream).
# apps/ builds and releases whatever you drop in it, but only the committed
# stub (README, discovery CMakeLists, template_app) travels with apex;
# forks tracking their own applications adjust these lines.
/apps/*
!/apps/CMakeLists.txt
!/apps/README.md
!/apps/template_app/
.ccache/

# Tooling coverage reports (nightly artifacts)
.coverage
coverage-py.xml
coverage-rust.lcov
